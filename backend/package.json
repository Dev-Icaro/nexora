{
  "name": "nexora-backend",
  "version": "1.0.0",
  "description": "Nexora backend API",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch --inspect --env-file=.env.development src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*\" \"tests/**/*\" --no-error-on-unmatched-pattern"
  },
  "engines": {
    "node": ">=22.0.0 <25.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "3.8.1",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0"
  }
}
