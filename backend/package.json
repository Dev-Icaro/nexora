{
  "name": "nexora-backend",
  "version": "1.0.0",
  "description": "Nexora backend API",
  "main": "dist/server.js",
  "license": "MIT",
  "scripts": {
    "build": "tsc && tsc-alias",
    "dev": "tsx watch --inspect --env-file=.env.development src/server.ts",
    "start": "node --env-file=.env.production dist/server.js",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*\" \"tests/**/*\" --no-error-on-unmatched-pattern",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix"
  },
  "engines": {
    "node": ">=22.0.0 <25.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "prettier": "^3.8.1",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.0.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@apollo/server": "^5.5.0",
    "bcrypt": "^6.0.0",
    "express-http-context": "^2.0.1",
    "graphql": "^16.13.2",
    "inversify": "6.2.2",
    "mongoose": "^9.4.1",
    "reflect-metadata": "^0.2.2",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.3.6"
  }
}
