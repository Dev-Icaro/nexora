{
  "compilerOptions": {
    /* ─── Projects ────────────────────────────────────────────────────────── */
    // "incremental": true,                    /* (TS 3.4) Save .tsbuildinfo files to enable incremental compilation. */
    // "composite": true,                      /* (TS 3.0) Enable constraints for project references. */
    // "tsBuildInfoFile": "./.tsbuildinfo",    /* (TS 3.4) Specify path for .tsbuildinfo incremental compilation file. */
    // "disableSourceOfProjectReferenceRedirect": true, /* (TS 3.7) Disable preferring source files instead of declaration files when referencing composite projects. */
    // "disableSolutionSearching": true,       /* (TS 3.8) Opt a project out of multi-project reference checking when editing. */
    // "disableReferencedProjectLoad": true,   /* (TS 4.0) Reduce the number of projects loaded automatically by TypeScript. */

    /* ─── Language and Environment ────────────────────────────────────────── */
    "target": "ES2022" /* (TS 1.0) Set the JavaScript language version for emitted code. */,
    // "lib": [],                              /* (TS 1.0) Specify a set of bundled library declaration files that describe the target runtime environment. */
    // "jsx": "preserve",                      /* (TS 1.6) Specify what JSX code is generated. */
    "experimentalDecorators": true /* (TS 1.5) Enable experimental support for legacy experimental decorators. */,
    "emitDecoratorMetadata": true /* (TS 1.5) Emit design-type metadata for decorated declarations in source files. */,
    // "jsxFactory": "",                       /* (TS 1.8) Specify the JSX factory function used when targeting React JSX emit. */
    // "jsxFragmentFactory": "",               /* (TS 2.0) Specify the JSX Fragment reference used for fragments when targeting React JSX emit. */
    // "jsxImportSource": "",                  /* (TS 4.1) Specify module specifier used to import the JSX factory functions when using 'jsx: react-jsx'. */
    // "reactNamespace": "",                   /* (TS 1.8) Specify the object invoked for 'createElement'. Only applies when targeting 'react' JSX emit. */
    // "noLib": true,                          /* (TS 1.0) Disable including any library files, including the default lib.d.ts. */
    // "useDefineForClassFields": true,        /* (TS 3.7) Emit ECMAScript-standard-compliant class fields. */
    // "moduleDetection": "auto",              /* (TS 4.7) Control what method is used to detect module-format JS files. */

    /* ─── Modules ─────────────────────────────────────────────────────────── */
    "module": "CommonJS" /* (TS 1.0) Specify what module code is generated. */,
    // "rootDir": "./src",                     /* (TS 1.5) Specify the root folder within your source files. */
    // "moduleResolution": "node10",           /* (TS 1.6) Specify how TypeScript looks up a file from a given module specifier. */
    // "baseUrl": "./",                        /* (TS 1.8) Specify the base directory to resolve non-relative module names. */
    "paths": {
      /* (TS 2.0) Specify a set of entries that re-map imports to additional lookup locations. */ "@/*": ["./src/*"]
    },
    // "rootDirs": [],                         /* (TS 2.0) Allow multiple folders to be treated as one when resolving modules. */
    // "typeRoots": [],                        /* (TS 2.0) Specify multiple folders that act like './node_modules/@types'. */
    "types": [
      "node",
      "reflect-metadata"
    ] /* (TS 2.0) Specify type package names to be included without being referenced in a source file. */,
    // "allowUmdGlobalAccess": true,           /* (TS 3.4) Allow accessing UMD globals from modules. */
    // "moduleSuffixes": [],                   /* (TS 4.7) List of file name suffixes to search when resolving a module. */
    // "allowImportingTsExtensions": true,     /* (TS 5.0) Allow imports to include TypeScript file extensions. */
    // "rewriteRelativeImportExtensions": true, /* (TS 5.7) Rewrite .ts/.tsx/.mts/.cts file extensions in relative import paths to their JavaScript equivalents in output files. */
    // "resolvePackageJsonExports": true,      /* (TS 4.7) Use the package.json 'exports' field when resolving package imports. */
    // "resolvePackageJsonImports": true,      /* (TS 4.7) Use the package.json 'imports' field when resolving imports. */
    // "customConditions": [],                 /* (TS 5.0) Conditions to set in addition to the resolver-specific defaults when resolving imports. */
    // "noUncheckedSideEffectImports": true,   /* (TS 5.6) Check side effect imports. */
    // "resolveJsonModule": true,              /* (TS 2.9) Enable importing .json files. */
    // "allowArbitraryExtensions": true,       /* (TS 5.0) Enable importing files with any extension, provided a declaration file is present. */
    // "noResolve": true,                      /* (TS 1.0) Disallow 'import's, 'require's or '<reference>'s from expanding the number of files TypeScript should add to a project. */

    /* ─── JavaScript Support ──────────────────────────────────────────────── */
    // "allowJs": true,                        /* (TS 1.8) Allow JavaScript files to be a part of your program. */
    // "checkJs": true,                        /* (TS 2.3) Enable error reporting in type-checked JavaScript files. */
    // "maxNodeModuleJsDepth": 1,              /* (TS 2.0) Specify the maximum folder depth used for checking JavaScript files from 'node_modules'. */

    /* ─── Emit ────────────────────────────────────────────────────────────── */
    // "declaration": true,                    /* (TS 1.0) Generate .d.ts files from TypeScript and JavaScript files in your project. */
    // "declarationMap": true,                 /* (TS 2.9) Create sourcemaps for d.ts files. */
    // "emitDeclarationOnly": true,            /* (TS 2.8) Only output d.ts files and not JavaScript files. */
    // "sourceMap": true,                      /* (TS 1.0) Create source map files for emitted JavaScript files. */
    // "inlineSourceMap": true,                /* (TS 1.5) Include sourcemap files inside the emitted JavaScript. */
    // "noEmit": true,                         /* (TS 1.4) Disable emitting files from a compilation. */
    // "outFile": "./",                        /* (TS 1.0) Specify a file that bundles all outputs into one JavaScript file. If 'declaration' is true, also designates a file that bundles all .d.ts output. */
    "outDir": "./dist" /* (TS 1.0) Specify an output folder for all emitted files. */,
    // "removeComments": true,                 /* (TS 1.0) Disable emitting comments. */
    // "importHelpers": true,                  /* (TS 2.1) Allow importing helper functions from tslib once per project, instead of including them per-file. */
    // "downlevelIteration": true,             /* (TS 2.3) Emit more compliant, but verbose and less performant JavaScript for iteration. */
    // "sourceRoot": "",                       /* (TS 1.0) Specify the root path for debuggers to find the reference source code. */
    // "mapRoot": "",                          /* (TS 1.0) Specify the location where debugger should locate map files instead of generated locations. */
    // "inlineSources": true,                  /* (TS 1.5) Include source code in the sourcemaps inside the emitted JavaScript. */
    // "emitBOM": true,                        /* (TS 1.0) Emit a UTF-8 Byte Order Mark (BOM) in the beginning of output files. */
    // "newLine": "crlf",                      /* (TS 1.5) Set the newline character for emitting files. */
    // "stripInternal": true,                  /* (TS 1.5) Disable emitting declarations that have '@internal' in their JSDoc comments. */
    // "noEmitHelpers": true,                  /* (TS 1.5) Disable generating custom helper functions like '__extends' in compiled output. */
    // "noEmitOnError": true,                  /* (TS 1.4) Disable emitting files if any type checking errors are reported. */
    // "preserveConstEnums": true,             /* (TS 1.0) Disable erasing 'const enum' declarations in generated code. */
    // "declarationDir": "./",                 /* (TS 2.0) Specify the output directory for generated declaration files. */
    // "preserveValueImports": true,           /* (TS 3.8) Preserve unused imported values in the JavaScript output that would otherwise be removed. */
    // "verbatimModuleSyntax": true,           /* (TS 5.0) Do not transform or elide any imports or exports not marked as type-only, ensuring they are written in the output file's format based on the 'module' setting. */

    /* ─── Interop Constraints ─────────────────────────────────────────────── */
    "isolatedModules": true /* (TS 1.5) Ensure that each file can be safely transpiled without relying on other imports. Required by tsx (esbuild transpiles files individually without full type information). */,
    // "verbatimModuleSyntax": true,           /* (TS 5.0) Do not transform or elide any imports or exports not marked as type-only. */
    // "isolatedDeclarations": true,           /* (TS 5.5) Require sufficient annotation on exports so other tools can trivially generate declaration files. */
    // "allowSyntheticDefaultImports": true,   /* (TS 1.8) Allow 'import x from y' when a module doesn't have a default export. */
    "esModuleInterop": true /* (TS 2.7) Emit additional JavaScript to ease support for importing CommonJS modules. */,
    // "preserveSymlinks": true,               /* (TS 2.5) Disable resolving symlinks to their realpath. This correlates to the same flag in node. */
    "forceConsistentCasingInFileNames": true /* (TS 1.8) Ensure that casing is correct in imports. */,

    /* ─── Type Checking ───────────────────────────────────────────────────── */
    "strict": true /* (TS 2.3) Enable all strict type-checking options. */,
    // "noImplicitAny": true,                  /* (TS 1.0) Enable error reporting for expressions and declarations with an implied 'any' type. (included in strict) */
    // "strictNullChecks": true,               /* (TS 2.0) When type checking, take into account 'null' and 'undefined'. (included in strict) */
    // "strictFunctionTypes": true,            /* (TS 2.6) When assigning functions, check to ensure parameters and the return values are subtype-compatible. (included in strict) */
    // "strictBindCallApply": true,            /* (TS 3.2) Check that the arguments for 'bind', 'call', and 'apply' methods match the original function. (included in strict) */
    // "strictPropertyInitialization": true,   /* (TS 2.7) Check for class properties that are declared but not set in the constructor. (included in strict) */
    // "strictBuiltinIteratorReturn": true,    /* (TS 5.6) Built-in iterators are instantiated with a 'TReturn' type of 'undefined' instead of 'any'. (included in strict) */
    // "noImplicitThis": true,                 /* (TS 2.0) Enable error reporting when 'this' is given the type 'any'. (included in strict) */
    // "useUnknownInCatchVariables": true,     /* (TS 4.4) Default catch clause variables as 'unknown' instead of 'any'. (included in strict) */
    // "alwaysStrict": true,                   /* (TS 2.1) Ensure 'use strict' is always emitted. (included in strict) */
    // "noUnusedLocals": true,                 /* (TS 2.0) Enable error reporting when local variables aren't read. */
    // "noUnusedParameters": true,             /* (TS 2.0) Raise an error when a function parameter isn't read. */
    // "exactOptionalPropertyTypes": true,     /* (TS 4.4) Interpret optional property types as written, rather than adding 'undefined'. */
    // "noImplicitReturns": true,              /* (TS 1.8) Enable error reporting for codepaths that do not explicitly return in a function. */
    // "noFallthroughCasesInSwitch": true,     /* (TS 1.8) Enable error reporting for fallthrough cases in switch statements. */
    // "noUncheckedIndexedAccess": true,       /* (TS 4.1) Add 'undefined' to a type when accessed using an index. */
    // "noImplicitOverride": true,             /* (TS 4.3) Ensure overriding members in derived classes are marked with an override modifier. */
    // "noPropertyAccessFromIndexSignature": true, /* (TS 4.2) Enforces using indexed accessors for keys declared using an indexed type. */
    // "allowUnusedLabels": true,              /* (TS 1.8) Disable error reporting for unused labels. */
    // "allowUnreachableCode": true,           /* (TS 1.8) Disable error reporting for unreachable code. */

    /* ─── Completeness ────────────────────────────────────────────────────── */
    // "skipDefaultLibCheck": true,            /* (TS 1.0) Skip type checking .d.ts files that are included with TypeScript. */
    "skipLibCheck": true /* (TS 2.0) Skip type checking all .d.ts files. */
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
